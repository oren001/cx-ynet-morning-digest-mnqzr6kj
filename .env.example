```
# Cloudflare KV Namespace IDs
# Create namespaces with: wrangler kv:namespace create "DIGEST_STORE"
# Replace these IDs with your actual namespace IDs from Cloudflare dashboard

# Main KV namespace for production
KV_NAMESPACE_ID=your_kv_namespace_id_here

# Preview KV namespace for development
KV_NAMESPACE_ID_PREVIEW=your_preview_kv_namespace_id_here

# Optional: Ynet API configuration (if using official API instead of scraping)
# YNET_API_KEY=your_ynet_api_key_here
# YNET_API_ENDPOINT=https://api.ynet.co.il/v1

# Debug and logging flags
DEBUG=false
LOG_LEVEL=info

# Cron schedule override (default: 0 6 * * * for 6 AM Israel time)
# CRON_SCHEDULE=0 6 * * *

# User preferences
DEFAULT_ARTICLES_COUNT=10
MIN_ARTICLES_COUNT=5
MAX_ARTICLES_COUNT=15

# Article scoring weights (0-1)
CATEGORY_PREFERENCE_WEIGHT=0.4
TIME_PATTERN_WEIGHT=0.2
CLICK_RATE_WEIGHT=0.3
RECENCY_WEIGHT=0.1

# Data retention (in days)
READING_HISTORY_TTL=90
DIGEST_METADATA_TTL=30

# Rate limiting
MAX_CLICKS_PER_HOUR=50
MAX_DIGESTS_PER_DAY=5

# Scraping configuration
SCRAPE_TIMEOUT_MS=10000
MAX_ARTICLES_TO_SCRAPE=50
RETRY_ATTEMPTS=3

# Israel timezone offset (for cron scheduling)
ISRAEL_TIMEZONE=Asia/Jerusalem
DIGEST_HOUR=6
```